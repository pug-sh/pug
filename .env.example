# Database
DATABASE_URL=postgres://your_user:your_password@localhost:5433/your_db?sslmode=disable

# ClickHouse
CLICKHOUSE_URL=clickhouse://default:default@localhost:9000/default

# NATS
NATS_URL=nats://localhost:4222

# Server
COTTON_SERVER_PORT=3000
COTTON_JWT_SECRET_KEY=your_jwt_secret_key_here
# Comma-separated list of allowed origins for CORS
# When set to *, credentials are not sent per CORS spec. Set specific origins to enable credentialed requests.
# Example: COTTON_CORS_ORIGINS=https://app.example.com,https://admin.example.com
COTTON_CORS_ORIGINS=http://localhost:5173
