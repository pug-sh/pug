# Database
# Matches infra/dev/docker-compose.yaml defaults.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/pug?sslmode=disable

# ClickHouse
# Matches infra/dev/docker-compose.yaml defaults.
CLICKHOUSE_URL=clickhouse://default:@localhost:9000/pug

# NATS
NATS_URL=nats://localhost:4222

# Worker liveness endpoint. Each worker process serves GET /healthz here,
# returning 200 while all of its workers are healthy and 503 otherwise.
# Unset defaults to :8090; set to "off" to disable. When running multiple
# worker binaries on one host, give each a distinct port to avoid a bind clash.
# (`pug dev` forces this off — liveness probing is for orchestrated deploys.)
# PUG_WORKER_HEALTH_ADDR=:8090

# Redis (Dragonfly)
REDIS_URL=redis://localhost:6380

# OpenTelemetry
# Export mode is auto-detected once at process start: if an OTLP endpoint var is
# set, pug exports traces, metrics, and logs to that collector; otherwise it logs
# to stdout as text (no collector needed — use this for deploys without OTLP).
# For local OTLP/HyperDX (`make clickstack`), uncomment the endpoint below.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Only used when exporting via OTLP:
OTEL_SERVICE_NAME=pug

# Server
PUG_SERVER_PORT=3000
PUG_JWT_SECRET_KEY=your_jwt_secret_key_here
# Comma-separated list of allowed origins for CORS
# When set to *, credentials are not sent per CORS spec. Set specific origins to enable credentialed requests.
# Example: PUG_CORS_ORIGINS=https://app.example.com,https://admin.example.com
PUG_CORS_ORIGINS=http://localhost:5173

# OAuth (Google sign-in via @react-oauth/google GoogleLogin credential)
# Leave empty to disable Google OAuth. Must match the dashboard VITE_GOOGLE_CLIENT_ID.
PUG_OAUTH_GOOGLE_CLIENT_ID=

# Email
PUG_DASHBOARD_BASE_URL=http://localhost:5173
PUG_EMAIL_FROM=noreply@example.com
PUG_EMAIL_REPLY_TO=
# Optional logo shown in the email header; empty renders a wordmark-only header.
PUG_EMAIL_LOGO_URL=
# Supported values: resend, ses
PUG_EMAIL_PROVIDER=resend
# Required when PUG_EMAIL_PROVIDER=resend
PUG_RESEND_API_KEY=your_resend_api_key_here
# Optional when PUG_EMAIL_PROVIDER=ses if AWS_REGION is already set
PUG_SES_REGION=us-east-1
# Standard AWS SDK credentials for SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# Optional for temporary AWS credentials
AWS_SESSION_TOKEN=

# Per-tenant email provider configuration is encrypted at rest with this key.
# Generate with: openssl rand -base64 32
# Leave empty to disable per-tenant providers (operator default handles all sends).
PUG_EMAIL_PROVIDER_SECRET_KEY=
