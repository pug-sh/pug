# Database
# Matches infra/dev/docker-compose.yaml defaults.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/pug?sslmode=disable

# ClickHouse
# Matches infra/dev/docker-compose.yaml defaults.
CLICKHOUSE_URL=clickhouse://default:@localhost:9000/pug

# NATS
NATS_URL=nats://localhost:4222

# Worker health endpoints. Each worker process serves GET /healthz (liveness:
# 200 while its consume loops run, 503 if wedged → restart the process) and GET
# /readyz (readiness: 200 once started and connected to NATS, 503 otherwise →
# gate rollouts / pull from rotation) on this address. Unset defaults to :8090;
# set to "off" to disable. When running multiple worker binaries on one host,
# give each a distinct port to avoid a bind clash. (`pug dev` forces this off —
# probing is for orchestrated deploys.)
# PUG_WORKER_HEALTH_ADDR=:8090

# Redis (Dragonfly)
#
# REQUIRES REDIS >= 7.0 (or a Dragonfly/Valkey reporting >= 7.0). Cookieless
# session stitching issues `SET key val EX <n> NX GET`, and NX+GET were only
# permitted together from 7.0. On 6.x every mint returns `ERR syntax error`
# WITHOUT creating the key, so it repeats for every event forever: all cookieless
# sessions silently collapse to one-per-visitor-day while ingestion otherwise
# looks healthy. Watch events.cookieless_session_degraded_total{reason=mint_failed}.
#
# THE SALT STORE MUST BE EPHEMERAL. The daily cookieless salt lives here, and its
# deletion is the entire privacy guarantee: the (project, IP, UA) input space is
# small enough to brute-force once a salt is known. TTL expiry only removes a key
# from the live keyspace — it cannot edit a snapshot already written to disk — so
# whatever backs this URL must have NO RDB/AOF/.dfs snapshotting, NO replica, and
# NO volume backup. For Dragonfly that means starting it with `--dbfilename=`
# (its default filename is non-empty, which saves on every graceful shutdown).
REDIS_URL=redis://localhost:6380

# OpenTelemetry
# Export mode is auto-detected once at process start: if an OTLP endpoint var is
# set, pug exports traces, metrics, and logs to that collector; otherwise it logs
# to stdout as text (no collector needed — use this for deploys without OTLP).
# For local OTLP/HyperDX (`make clickstack`), uncomment the endpoint below.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Only used when exporting via OTLP:
OTEL_SERVICE_NAME=pug

# Server
PUG_SERVER_PORT=3000
PUG_JWT_SECRET_KEY=your_jwt_secret_key_here
# Comma-separated list of allowed origins for CORS
# When set to *, credentials are not sent per CORS spec. Set specific origins to enable credentialed requests.
# Example: PUG_CORS_ORIGINS=https://app.example.com,https://admin.example.com
PUG_CORS_ORIGINS=http://localhost:5173

# OAuth (Google sign-in via @react-oauth/google GoogleLogin credential)
# Leave empty to disable Google OAuth. Must match the dashboard VITE_GOOGLE_CLIENT_ID.
PUG_OAUTH_GOOGLE_CLIENT_ID=

# Demo traffic generator (Pug & Pals rolling seed)
# PUG_DEMO_ENABLED is the single demo switch. Off (default) means no demo
# anywhere; true turns it on. It gates the rolling demo worker in BOTH `pug dev`
# and the standalone `pug worker demo`: when off, `pug dev` skips it and the
# standalone command idles (stays running but generates no traffic, so a k8s
# Deployment doesn't restart-loop on exit). The worker derives its demo project
# from the demo user (woof@pug.sh), creating the customer/org/project on a fresh
# database. If the project has no events yet it backfills a
# few months of ClickHouse history — so the public demo dashboard has history
# behind the live feed — then seeds profiles only for the users those events
# belong to (never for a user with no events), and finally streams live sessions
# straight into ClickHouse (the same insert path as the backfill; no NATS hop).
# For a one-shot local seed without the live stream, use `pug seed`.
#
# `pug server` ALSO reads this flag: when true it exposes the credential-less
# AuthService.DemoSignIn RPC, which mints a read-only viewer session for the
# seeded snoop@pug.sh account so visitors to the public demo page are signed in
# automatically. So on a demo deployment set PUG_DEMO_ENABLED=true on every pod
# (server + worker); leave it false everywhere else and the demo is fully off.
PUG_DEMO_ENABLED=false
# Peak sessions spawned per minute at the busiest hour; off-peak follows a
# diurnal/weekly curve. 6 ≈ 30-50k events/day.
PUG_DEMO_PEAK_SESSIONS_PER_MIN=6
# One-time backfill volume when the demo project is empty.
PUG_DEMO_SEED_COUNT=500000
PUG_DEMO_SEED_BATCH=10000

# Email
PUG_DASHBOARD_BASE_URL=http://localhost:5173
PUG_EMAIL_FROM=noreply@example.com
PUG_EMAIL_REPLY_TO=
# Optional logo shown in the email header; empty renders a wordmark-only header.
PUG_EMAIL_LOGO_URL=https://pug.sh/logo.png
# Supported values: resend, ses
PUG_EMAIL_PROVIDER=resend
# Required when PUG_EMAIL_PROVIDER=resend
PUG_RESEND_API_KEY=your_resend_api_key_here
# Optional when PUG_EMAIL_PROVIDER=ses if AWS_REGION is already set
PUG_SES_REGION=us-east-1
# Standard AWS SDK credentials for SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# Optional for temporary AWS credentials
AWS_SESSION_TOKEN=

# Per-tenant email provider configuration is encrypted at rest with this key.
# Generate with: openssl rand -base64 32
# Leave empty to disable per-tenant providers (operator default handles all sends).
PUG_EMAIL_PROVIDER_SECRET_KEY=
