{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-server",
      "type": "shell",
      "command": "go",
      "args": ["build", "-o", "bin/server", "./cmd/server"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": ["$go"],
      "options": {
        "envFile": ["${workspaceFolder}/.env"]
      }
    },
    {
      "label": "build-migrate",
      "type": "shell",
      "command": "go",
      "args": ["build", "-o", "bin/migrate", "./cmd/migrate"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": ["$go"],
      "options": {
        "envFile": ["${workspaceFolder}/.env"]
      }
    },
    {
      "label": "run-migrations",
      "type": "shell",
      "command": "go",
      "args": ["run", "./cmd/migrate", "-direction", "up"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "options": {
        "envFile": ["${workspaceFolder}/.env"]
      }
    }
  ]
}
